{
  "manifest_version": 3,
  "name": "Medlean Auto Annotator",
  "version": "0.1.0",
  "description": "メドレー音声をキャプチャして自動アノテーションを行います",
  "permissions": [
    "tabCapture",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:*/*",
    "https://anasui-e6f49.web.app/*",
    "https://*.nicovideo.jp/*",
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://anasui-e6f49.web.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
